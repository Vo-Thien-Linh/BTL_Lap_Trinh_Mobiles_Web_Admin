@model Web_Admin_Booking_App.Models.AppointmentIndexViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Yêu cầu hủy lịch";
    ViewData["PageTitle"] = "Yêu cầu hủy lịch";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <div class="eyebrow">Hàng đợi xử lý</div>
            <h1 class="admin-page-title">Duyệt yêu cầu hủy lịch</h1>
            <p class="admin-page-subtitle">Xem lý do hủy lịch của bệnh nhân và xử lý yêu cầu.</p>
        </div>
    </div>

    <div class="admin-stat-grid mb-3">
        <div class="admin-stat-card"><span class="admin-stat-label">Chờ duyệt</span><strong class="admin-stat-value">@Model.TotalCount</strong><small>Yêu cầu đang chờ xử lý</small></div>
        <div class="admin-stat-card"><span class="admin-stat-label">Gửi hôm nay</span><strong class="admin-stat-value">@Model.TodayCount</strong><small>Yêu cầu mới trong ngày</small></div>
        <div class="admin-stat-card"><span class="admin-stat-label">Đã duyệt hôm nay</span><strong class="admin-stat-value">0</strong><small>Đọc từ lịch sử xử lý nếu có</small></div>
        <div class="admin-stat-card"><span class="admin-stat-label">Đã từ chối hôm nay</span><strong class="admin-stat-value">0</strong><small>Đọc từ lịch sử xử lý nếu có</small></div>
    </div>

    <form asp-controller="CancelRequests" asp-action="Index" method="get" class="filter-toolbar mb-3">
        <div class="filter-search">
            <span>⌕</span>
            <input name="search" value="@Model.Search" class="form-control" autocomplete="off" placeholder="Tìm theo mã lịch, mã bệnh nhân, tên bệnh nhân, bác sĩ, lý do hủy..." />
        </div>
        <button type="submit" class="btn btn-primary">Tìm kiếm</button>
    </form>

    <div class="admin-table-card">
        <div class="table-responsive">
            <table class="table align-middle mb-0 admin-table">
                <thead>
                    <tr>
                        <th>Mã yêu cầu</th>
                        <th>Mã lịch hẹn</th>
                        <th>Bệnh nhân</th>
                        <th>Bác sĩ</th>
                        <th>Ngày/giờ khám</th>
                        <th>Lý do hủy</th>
                        <th>Thời gian gửi</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="9"><div class="empty-state">Không có yêu cầu hủy lịch chờ xử lý.</div></td></tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@CancelRequestCode(item)</td>
                            <td>@item.AppointmentCode</td>
                            <td>
                                <div class="fw-semibold">@item.PatientName</div>
                                <div class="text-secondary small">Mã bệnh nhân: @TextOrDefault(item.PatientCode)</div>
                            </td>
                            <td>@TextOrDefault(item.DoctorName)</td>
                            <td>@item.ScheduledAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-break-soft">@TextOrDefault(item.CancelReason)</td>
                            <td>@(item.CancelRequestedAt?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa cập nhật")</td>
                            <td><span class="admin-badge admin-badge--warning">Chờ duyệt hủy</span></td>
                            <td class="text-end">
                                <div class="d-flex flex-column gap-2 align-items-end">
                                    <form asp-controller="CancelRequests" asp-action="Approve" asp-route-id="@item.DocumentId" method="post" onsubmit="return confirm('Duyệt hủy lịch này và trả lại slot cho ca làm việc?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">Duyệt hủy</button>
                                    </form>
                                    <form asp-controller="CancelRequests" asp-action="Reject" asp-route-id="@item.DocumentId" method="post" class="d-flex flex-wrap gap-2 justify-content-end" onsubmit="return confirm('Từ chối yêu cầu hủy lịch này?');">
                                        @Html.AntiForgeryToken()
                                        <input name="rejectReason" class="form-control form-control-sm" maxlength="250" required placeholder="Lý do từ chối" style="max-width: 220px;" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Từ chối</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</section>

@functions {
    private static string TextOrDefault(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "Chưa cập nhật" : value;

    private static string CancelRequestCode(Web_Admin_Booking_App.Models.AppointmentListItemViewModel item) =>
        $"CR-{(string.IsNullOrWhiteSpace(item.AppointmentCode) ? item.DocumentId : item.AppointmentCode)}";
}
