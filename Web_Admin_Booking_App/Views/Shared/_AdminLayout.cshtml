@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var adminName = User.Identity?.Name ?? "Admin User";
    string Active(string controller, string? action = null)
    {
        if (!currentController.Equals(controller, StringComparison.OrdinalIgnoreCase)) return string.Empty;
        if (action is null) return "admin-nav__link--active";
        return currentAction.Equals(action, StringComparison.OrdinalIgnoreCase) ? "admin-nav__link--active" : string.Empty;
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediAdmin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div class="admin-brand">
                <div class="admin-brand__mark">+</div>
                <div>
                    <div class="admin-brand__logo">MediAdmin</div>
                    <div class="admin-brand__sub">Hệ thống Quản trị Y tế</div>
                </div>
            </div>

            <nav class="admin-nav" aria-label="Điều hướng quản trị">
                <a class="admin-nav__link @(Active("Home", "Index"))" asp-controller="Home" asp-action="Index"><span class="admin-nav__dot"></span><span>Dashboard</span></a>
                <a class="admin-nav__link @(Active("Doctors"))" asp-controller="Doctors" asp-action="Index"><span class="admin-nav__dot"></span><span>Bác sĩ</span></a>
                <a class="admin-nav__link @(Active("Specialties"))" asp-controller="Specialties" asp-action="Index"><span class="admin-nav__dot"></span><span>Chuyên khoa</span></a>
                <a class="admin-nav__link @(Active("Appointments"))" asp-controller="Appointments" asp-action="Index"><span class="admin-nav__dot"></span><span>Lịch hẹn</span></a>
                <a class="admin-nav__link @(Active("MedicalRecords"))" asp-controller="MedicalRecords" asp-action="Index"><span class="admin-nav__dot"></span><span>Bệnh án</span></a>
                <a class="admin-nav__link @(Active("Payments"))" asp-controller="Payments" asp-action="Index"><span class="admin-nav__dot"></span><span>Thanh toán</span></a>
                <a class="admin-nav__link @(Active("Patients"))" asp-controller="Patients" asp-action="Index"><span class="admin-nav__dot"></span><span>Bệnh nhân</span></a>
                <a class="admin-nav__link @(Active("WorkShifts"))" asp-controller="WorkShifts" asp-action="Index"><span class="admin-nav__dot"></span><span>Ca làm việc</span></a>
            </nav>

            <div class="admin-sidebar__bottom">
                <a class="btn btn-light w-100 admin-cta" asp-controller="Appointments" asp-action="Create">
                    Tạo lịch hẹn mới
                </a>

                <a class="admin-nav__link admin-sidebar-action" href="#">
                    <span class="admin-nav__dot"></span>
                    <span>Cài đặt</span>
                </a>

                <form asp-controller="Auth" asp-action="Logout" method="post" class="admin-logout-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="admin-nav__link admin-sidebar-action admin-nav__link--logout">
                        <span class="admin-nav__logout-icon" aria-hidden="true">↪</span>
                        <span>Đăng xuất</span>
                    </button>
                </form>
            </div>
        </aside>

        <section class="admin-main">
            <header class="admin-topbar">
                <div>
                    <div class="admin-topbar__title">@ViewData["PageTitle"]</div>
                    <div class="admin-topbar__subtitle">Quản trị dữ liệu bệnh viện theo thời gian thực</div>
                </div>
                <div class="admin-topbar__search">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white border-end-0">⌕</span>
                        <input class="form-control border-start-0" type="search" placeholder="Tìm kiếm bác sĩ, khoa, bệnh nhân..." />
                    </div>
                </div>
                <div class="admin-topbar__right">
                    <button type="button" class="btn btn-sm btn-outline-secondary admin-icon-btn">🔔</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary admin-icon-btn">?</button>
                    <div class="admin-user">
                        <div class="admin-user__meta">
                            <div class="admin-user__name">@adminName</div>
                            <div class="admin-user__role">Administrator</div>
                        </div>
                        <div class="admin-user__avatar">@((adminName.Length >= 2 ? adminName[..2] : "AU").ToUpperInvariant())</div>
                    </div>
                </div>
            </header>

            <main class="admin-content">
                @if (TempData["SuccessMessage"] is string success)
                {
                <div class="alert alert-success border-0 shadow-sm admin-alert">@success</div>
                }
                @if (TempData["ErrorMessage"] is string error)
                {
                <div class="alert alert-danger border-0 shadow-sm admin-alert">@error</div>
                }
                @RenderBody()
            </main>
        </section>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
