@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Không có quyền truy cập";
}

<div class="auth-card auth-card--warning">
    <div class="auth-card__header">
        <div class="auth-card__icon auth-card__icon--danger">!</div>
        <h2>Không có quyền truy cập</h2>
        <p>Tài khoản của bạn không có quyền Admin để vào trang quản trị.</p>
    </div>

    <form asp-controller="Auth" asp-action="Logout" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-danger auth-submit">Đăng nhập bằng tài khoản khác</button>
    </form>
</div>
