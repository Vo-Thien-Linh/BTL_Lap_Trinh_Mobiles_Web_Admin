@{
    Layout = "_AuthLayout";
}
<div class="container" style="max-width: 560px; margin-top: 70px;">
    <div class="alert alert-danger shadow-sm">
        <h4 class="alert-heading">Không có quyền truy cập</h4>
        <p>Tài khoản của bạn không có quyền Admin để vào trang quản trị.</p>
        <hr />
        <form asp-controller="Auth" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">Đăng nhập bằng tài khoản khác</button>
        </form>
    </div>
</div>
