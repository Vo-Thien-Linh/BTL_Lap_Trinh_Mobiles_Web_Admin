@model Web_Admin_Booking_App.Models.SpecialtyUpsertViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm chuyên khoa";
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
    <div>
        <div class="eyebrow">Danh mục y tế</div>
        <h1 class="page-title mb-1">Thêm chuyên khoa mới</h1>
        <p class="text-secondary mb-0">Tạo mới chuyên khoa trong hệ thống.</p>
    </div>
    <a class="btn btn-light" asp-controller="Specialties" asp-action="Index">Quay lại</a>
</div>

<partial name="_SpecialtyForm" model="Model" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
