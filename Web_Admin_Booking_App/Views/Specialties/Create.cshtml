@model Web_Admin_Booking_App.Models.SpecialtyUpsertViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm chuyên khoa";
    ViewData["PageTitle"] = "Thêm chuyên khoa";
}

<section class="admin-form-page">
    <div class="admin-page-header admin-page-header--compact">
        <div>
            <div class="admin-page-kicker">Chuyên khoa</div>
            <h1 class="admin-page-title">Thêm chuyên khoa mới</h1>
            <p class="admin-page-subtitle">Tạo mới chuyên khoa, phòng khám và thông tin hiển thị trong hệ thống.</p>
        </div>
        <a class="admin-action-btn" asp-controller="Specialties" asp-action="Index">Quay lại</a>
    </div>

    <partial name="_SpecialtyForm" model="Model" />
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
