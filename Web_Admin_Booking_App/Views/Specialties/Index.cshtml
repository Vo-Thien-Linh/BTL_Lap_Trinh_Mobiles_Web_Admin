@model Web_Admin_Booking_App.Models.SpecialtyIndexViewModel
@using Web_Admin_Booking_App.Models
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý chuyên khoa";
}

<section class="page-hero mb-4">
    <div>
        <div class="eyebrow">Danh mục y tế</div>
        <h1>Quản lý chuyên khoa</h1>
        <p>Thêm, chỉnh sửa, xóa và theo dõi trạng thái chuyên khoa.</p>
    </div>
    <a class="btn btn-primary admin-btn-plus" asp-controller="Specialties" asp-action="Create"><span>+</span> Thêm chuyên khoa mới</a>
</section>

@if (TempData["SuccessMessage"] != null)
{
<div class="alert alert-success rounded-4 border-0 shadow-sm">@TempData["SuccessMessage"]</div>
}

<div class="admin-stat-grid mb-4">
    <div class="admin-stat-card">
        <span class="admin-stat-card__label">Tổng số chuyên khoa</span>
        <strong>@Model.TotalCount</strong>
        <small>Danh mục hiện có trong hệ thống</small>
    </div>
    <div class="admin-stat-card">
        <span class="admin-stat-card__label">Đang hoạt động</span>
        <strong>@Model.ActiveCount</strong>
        <small>Chuyên khoa đang tiếp nhận lịch</small>
    </div>
    <div class="admin-stat-card">
        <span class="admin-stat-card__label">Mới tháng này</span>
        <strong>@Model.NewThisMonthCount</strong>
        <small>@(string.IsNullOrWhiteSpace(Model.NewThisMonthNames) ? "Chưa có chuyên khoa mới" : Model.NewThisMonthNames)</small>
    </div>
</div>

<form id="specialtyFilterForm" asp-controller="Specialties" asp-action="Index" method="get" class="filter-toolbar mb-3">
    <div class="filter-search">
        <span>⌕</span>
        <input name="search" value="@Model.Search" class="form-control" autocomplete="off" placeholder="Tìm theo tên, mã khoa, trưởng khoa, vị trí..." />
    </div>
    <select name="statusFilter" class="form-select filter-select">
        <option value="">Tất cả trạng thái</option>
        <option value="Active" selected="@(Model.StatusFilter == "Active")">Đang hoạt động</option>
        <option value="Paused" selected="@(Model.StatusFilter == "Paused")">Tạm ngưng</option>
    </select>
</form>

<div id="specialtyResults">
    <partial name="_SpecialtyTable" model="Model" />
</div>

@section Scripts {
    <script>
        (() => {
            const form = document.getElementById('specialtyFilterForm');
            const target = document.getElementById('specialtyResults');
            if (!form || !target) return;

            let timer;
            const submitRealtime = () => {
                clearTimeout(timer);
                timer = setTimeout(async () => {
                    const url = `${form.action}?${new URLSearchParams(new FormData(form)).toString()}`;
                    target.classList.add('is-loading');
                    const response = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                    target.innerHTML = await response.text();
                    target.classList.remove('is-loading');
                    window.history.replaceState(null, '', url);
                }, 300);
            };

            form.querySelectorAll('input, select').forEach(el => {
                el.addEventListener('input', submitRealtime);
                el.addEventListener('change', submitRealtime);
            });
        })();
    </script>
}
