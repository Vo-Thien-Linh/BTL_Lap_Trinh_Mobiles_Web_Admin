@model Web_Admin_Booking_App.Models.SpecialtyUpsertViewModel
@using Web_Admin_Booking_App.Models
@{
    var isEdit = !string.IsNullOrWhiteSpace(Model.Id);
}

<div class="card panel-card form-card">
    <div class="card-body p-4">
        <form method="post" enctype="multipart/form-data" class="row g-4" id="specialtyUpsertForm">
            @Html.AntiForgeryToken()
            @if (isEdit)
            {
                <input type="hidden" asp-for="Id" />
            }
            <input type="hidden" asp-for="Code" />
            <input type="hidden" asp-for="ImageUrl" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="col-lg-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control form-control-lg js-specialty-name" placeholder="VD: Khoa Tim mạch" list="specialtyNameSuggestions" autocomplete="off" />
                <datalist id="specialtyNameSuggestions">
                    @foreach (var name in Model.ExistingNames)
                    {
                        <option value="@name"></option>
                    }
                </datalist>
                <div class="form-hint js-name-warning d-none">Tên này đã hoặc gần giống chuyên khoa đang có.</div>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="col-lg-6">
                <label class="form-label">Mã khoa</label>
                <input class="form-control form-control-lg bg-light text-secondary" value="@(isEdit && !string.IsNullOrWhiteSpace(Model.Code) ? Model.Code : Model.CodePreview)" readonly />
                <div class="form-hint">Admin không cần nhập mã khoa thủ công.</div>
            </div>

            <div class="col-lg-6">
                <label asp-for="Phone" class="form-label"></label>
                <input asp-for="Phone" class="form-control" placeholder="VD: 0281234567" autocomplete="off" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="col-lg-6">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-select">
                    <option value="Active">Đang hoạt động</option>
                    <option value="Paused">Tạm ngưng</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="col-lg-6">
                <label asp-for="LocationNote" class="form-label"></label>
                <input asp-for="LocationNote" class="form-control" placeholder="VD: Tầng 4 - Khu A" list="locationSuggestions" autocomplete="off" />
                <datalist id="locationSuggestions">
                    @foreach (var location in Model.LocationSuggestions)
                    {
                        <option value="@location"></option>
                    }
                </datalist>
                <span asp-validation-for="LocationNote" class="text-danger"></span>
            </div>

            <div class="col-lg-6">
                <label asp-for="LogoFile" class="form-label"></label>
                <input asp-for="LogoFile" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    <div class="form-hint">Logo hiện tại: @Model.ImageUrl</div>
                }
                <span asp-validation-for="LogoFile" class="text-danger"></span>
            </div>

            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả ngắn về khoa"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="col-12">
                <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                    <label asp-for="RoomsText" class="form-label mb-0"></label>
                    <button class="btn btn-sm btn-outline-primary" type="button" id="addRoomButton">+ Thêm phòng</button>
                </div>
                <div id="roomList" class="d-grid gap-2">
                    @{
                        var rooms = Model.RoomNumbers.Count > 0 ? Model.RoomNumbers : new List<string> { string.Empty };
                    }
                    @for (var i = 0; i < rooms.Count; i++)
                    {
                        <div class="input-group room-row">
                            <input class="form-control" name="RoomNumbers" value="@rooms[i]" placeholder="VD: P.101" />
                            <button class="btn btn-outline-danger room-remove" type="button">Xóa</button>
                        </div>
                    }
                </div>
                <div class="form-hint">Mỗi ô là một phòng. Web sẽ lưu theo dạng rooms: roomId, roomNumber, name, isActive.</div>
            </div>

            <div class="col-12 d-flex gap-2 pt-2">
                <button type="submit" class="btn btn-primary px-4">@(isEdit ? "Lưu thay đổi" : "Lưu chuyên khoa")</button>
                <a class="btn btn-outline-secondary px-4" asp-controller="Specialties" asp-action="Index">Hủy</a>
            </div>
        </form>
    </div>
</div>

<script>
(() => {
    const existingNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ExistingNames));
    const normalize = value => (value || '').trim().toLowerCase();

    function bindWarning(inputSelector, warningSelector, values) {
        const input = document.querySelector(inputSelector);
        const warning = document.querySelector(warningSelector);
        if (!input || !warning) return;
        input.addEventListener('input', () => {
            const key = normalize(input.value);
            const matched = key.length >= 2 && values.some(x => normalize(x).includes(key) || normalize(x) === key);
            warning.classList.toggle('d-none', !matched);
        });
    }

    bindWarning('.js-specialty-name', '.js-name-warning', existingNames);

    const roomList = document.getElementById('roomList');
    const addRoomButton = document.getElementById('addRoomButton');

    function bindRemove(button) {
        button.addEventListener('click', () => {
            const rows = roomList.querySelectorAll('.room-row');
            if (rows.length <= 1) {
                const input = button.closest('.room-row')?.querySelector('input');
                if (input) input.value = '';
                return;
            }
            button.closest('.room-row')?.remove();
        });
    }

    addRoomButton?.addEventListener('click', () => {
        const row = document.createElement('div');
        row.className = 'input-group room-row';
        row.innerHTML = '<input class="form-control" name="RoomNumbers" placeholder="VD: P.101" /><button class="btn btn-outline-danger room-remove" type="button">Xóa</button>';
        roomList.appendChild(row);
        bindRemove(row.querySelector('.room-remove'));
        row.querySelector('input')?.focus();
    });

    roomList?.querySelectorAll('.room-remove').forEach(bindRemove);
})();
</script>
