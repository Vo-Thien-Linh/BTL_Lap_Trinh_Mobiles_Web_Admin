@model Web_Admin_Booking_App.Models.MedicineIndexViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý thuốc";
}

<div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <div class="fw-bold fs-5">Quản lý thuốc</div>
        <div class="text-secondary">Theo dõi danh mục thuốc, giá bán và tồn kho.</div>
    </div>
    <a class="btn btn-primary" asp-controller="Medicines" asp-action="Create">Thêm thuốc</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card stat-card"><div class="card-body"><div class="stat-card__label">Tổng số thuốc</div><div class="stat-card__value">@Model.TotalCount</div></div></div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card"><div class="card-body"><div class="stat-card__label">Sắp hết</div><div class="stat-card__value">@Model.LowStockCount</div></div></div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card"><div class="card-body"><div class="stat-card__label">Giá trị tồn</div><div class="stat-card__value">@Vnd(Model.InventoryValue)</div></div></div>
    </div>
</div>

<form class="d-flex flex-wrap gap-2 mb-3" method="get" asp-controller="Medicines" asp-action="Index">
    <input class="form-control" style="max-width: 360px" name="search" value="@Model.Search" placeholder="Tìm tên thuốc, mã, hàm lượng..." />
    <select class="form-select" style="max-width: 240px" name="groupFilter">
        <option value="">Tất cả nhóm thuốc</option>
        @foreach (var group in Model.Groups)
        {
            <option value="@group" selected="@(string.Equals(Model.GroupFilter, group, StringComparison.OrdinalIgnoreCase))">@group</option>
        }
    </select>
    <button class="btn btn-outline-primary" type="submit">Lọc</button>
    <a class="btn btn-light" asp-controller="Medicines" asp-action="Index">Xóa lọc</a>
</form>

<div class="card panel-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0 admin-table">
                <thead>
                    <tr class="text-secondary">
                        <th>Mã thuốc</th>
                        <th>Tên thuốc</th>
                        <th>Hàm lượng</th>
                        <th>Đơn vị</th>
                        <th>Đơn giá</th>
                        <th>Nhóm thuốc</th>
                        <th>Tồn kho</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="9" class="text-center text-secondary py-4">Chưa có thuốc phù hợp.</td></tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.MedicineCode</td>
                            <td>@item.Name</td>
                            <td>@item.Strength</td>
                            <td>@item.Unit</td>
                            <td>@Vnd(item.UnitPrice)</td>
                            <td>@item.Group</td>
                            <td>
                                <span class="fw-semibold @(item.Quantity <= 10 ? "text-danger" : "")">@item.Quantity</span>
                            </td>
                            <td>
                                <span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-secondary")">@(item.IsActive ? "Đang dùng" : "Tạm ngưng")</span>
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Medicines" asp-action="Edit" asp-route-id="@item.Id">Sửa</a>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@functions {
    private static string Vnd(decimal amount)
    {
        var value = string.Format(System.Globalization.CultureInfo.GetCultureInfo("vi-VN"), "{0:N0}", amount);
        return value + " đ";
    }
}
