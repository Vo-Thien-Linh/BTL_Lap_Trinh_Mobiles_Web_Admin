@model Web_Admin_Booking_App.Models.AppointmentIndexViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Lịch hẹn";
    ViewData["PageTitle"] = "Quản lý lịch hẹn";
    var cancelRequestedCount = Model.Items.Count(x => x.Status == Web_Admin_Booking_App.Models.AppointmentStatus.CancelRequested);
    var statusFilter = Model.StatusFilter;
    var weeklySchedule = ViewData["WeeklySchedule"] as Web_Admin_Booking_App.Models.WeeklyScheduleTableViewModel ?? new Web_Admin_Booking_App.Models.WeeklyScheduleTableViewModel();
    var isStaff = User.IsInRole("staff");
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <div class="eyebrow">Điều phối khám bệnh</div>
            <h1 class="admin-page-title">Quản lý lịch hẹn</h1>
            <p class="admin-page-subtitle">Theo dõi lịch khám, bệnh nhân, bác sĩ phụ trách và trạng thái xử lý.</p>
        </div>
        @if (isStaff)
        {
            <a class="admin-action-btn admin-action-btn--primary" asp-controller="Appointments" asp-action="Create">+ Tạo lịch hẹn</a>
        }
    </div>

    @if (TempData["InfoMessage"] is string infoMessage)
    {
        <div class="alert alert-info border-0 rounded-4">@infoMessage</div>
    }

    <div class="admin-stat-grid mb-3">
        <div class="admin-stat-card"><span class="admin-stat-label">Tổng lịch hẹn</span><strong class="admin-stat-value">@Model.TotalCount</strong><small>Tất cả lịch phù hợp bộ lọc</small></div>
        <div class="admin-stat-card"><span class="admin-stat-label">Hôm nay</span><strong class="admin-stat-value">@Model.TodayCount</strong><small>Lịch trong ngày</small></div>
        <div class="admin-stat-card"><span class="admin-stat-label">Chờ xác nhận</span><strong class="admin-stat-value">@Model.PendingCount</strong><small>Cần kiểm tra</small></div>
        <div class="admin-stat-card"><span class="admin-stat-label">Đang xử lý</span><strong class="admin-stat-value">@Model.ActiveCount</strong><small>@cancelRequestedCount yêu cầu hủy</small></div>
    </div>

    <div class="admin-filter-card mb-3">
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-sm @(string.IsNullOrWhiteSpace(statusFilter) ? "btn-primary" : "btn-outline-secondary")" asp-controller="Appointments" asp-action="Index">Tất cả</a>
            <a class="btn btn-sm @(statusFilter == nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Pending) ? "btn-primary" : "btn-outline-secondary")" asp-controller="Appointments" asp-action="Index" asp-route-statusFilter="@nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Pending)">Chờ xác nhận</a>
            <a class="btn btn-sm @(statusFilter == nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Confirmed) ? "btn-primary" : "btn-outline-secondary")" asp-controller="Appointments" asp-action="Index" asp-route-statusFilter="@nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Confirmed)">Đã xác nhận</a>
            <a class="btn btn-sm @(statusFilter == nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Completed) ? "btn-primary" : "btn-outline-secondary")" asp-controller="Appointments" asp-action="Index" asp-route-statusFilter="@nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Completed)">Đã khám</a>
            <a class="btn btn-sm @(statusFilter == nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Cancelled) ? "btn-primary" : "btn-outline-secondary")" asp-controller="Appointments" asp-action="Index" asp-route-statusFilter="@nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Cancelled)">Đã hủy</a>
            <a class="btn btn-sm btn-outline-warning" asp-controller="CancelRequests" asp-action="Index">Yêu cầu hủy lịch</a>
        </div>
    </div>

    <div class="admin-table-card doctor-schedule-card mb-3">
        <div class="doctor-schedule-card__toolbar">
            <div>
                <div class="fw-bold">Lịch làm việc theo tuần</div>
                <div class="text-secondary small">Chọn tuần để cập nhật riêng khung lịch, không reload toàn trang.</div>
            </div>
            <div class="btn-group btn-group-sm" role="group" aria-label="Chọn tuần lịch làm việc">
                <button type="button" class="btn btn-outline-secondary" data-week-offset="-1">Tuần trước</button>
                <button type="button" class="btn btn-primary" data-week-offset="0">Tuần này</button>
                <button type="button" class="btn btn-outline-secondary" data-week-offset="1">Tuần sau</button>
            </div>
        </div>
        <div id="doctorScheduleContainer" class="doctor-schedule-container" data-schedule-url="@Url.Action("DoctorSchedulePartial", "Appointments")">
            <partial name="_DoctorSchedulePartial" model="weeklySchedule" />
        </div>
    </div>

    <div id="appointmentResults" class="admin-table-card">
        <div class="table-responsive">
            <table class="table align-middle mb-0 admin-table">
                <thead>
                    <tr>
                        <th>Mã lịch hẹn</th>
                        <th>Bệnh nhân</th>
                        <th>Bác sĩ</th>
                        <th>Ngày/giờ</th>
                        <th>Chuyên khoa</th>
                        <th>STT</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="8"><div class="empty-state">Chưa có lịch hẹn nào.</div></td></tr>
                }
                else
                {
                    foreach (var a in Model.Items)
                    {
                        var isSelected = IsSelected(a, Model.SelectedId);
                        <tr class="@(isSelected ? "appointment-row--selected" : "")" id="appointment-@a.DocumentId">
                            <td>
                                <div class="fw-semibold">@ValueOrDash(a.AppointmentCode)</div>
                                @if (!string.IsNullOrWhiteSpace(a.ScheduleId))
                                {
                                    <div class="text-secondary small">Mã ca: @a.ScheduleId</div>
                                }
                            </td>
                            <td>
                                <div class="fw-semibold">@ValueOrDash(a.PatientName)</div>
                                <div class="text-secondary small">@ValueOrDash(a.PatientCode)</div>
                                <div class="text-secondary small">@ValueOrDash(a.PatientPhone)</div>
                            </td>
                            <td>
                                <div class="fw-semibold">@ValueOrDash(a.DoctorName)</div>
                                <div class="text-secondary small">@ValueOrDash(a.DoctorCode)</div>
                            </td>
                            <td>
                                <div class="fw-semibold">@a.ScheduledAt.ToString("HH:mm")</div>
                                <div class="text-secondary small">@a.ScheduledAt.ToString("dd/MM/yyyy")</div>
                            </td>
                            <td>@ValueOrDash(a.SpecialtyName)</td>
                            <td>@(a.QueueNumber > 0 ? a.QueueNumber.ToString() : "-")</td>
                            <td>
                                <span class="admin-badge @BadgeFor(a.Status)">@StatusText(a.Status)</span>
                                @if (a.Status == Web_Admin_Booking_App.Models.AppointmentStatus.CancelRequested)
                                {
                                    <div class="text-warning small mt-1">Chờ duyệt hủy</div>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex flex-column gap-2 align-items-end">
                                    <a class="btn btn-sm btn-light" asp-controller="Appointments" asp-action="Index" asp-route-selectedId="@a.DocumentId">Xem chi tiết</a>
                                    @if (a.Status == Web_Admin_Booking_App.Models.AppointmentStatus.CancelRequested)
                                    {
                                        <a class="btn btn-sm btn-outline-warning" asp-controller="CancelRequests" asp-action="Index" asp-route-search="@a.AppointmentCode">Xem yêu cầu hủy</a>
                                    }
                                    else if (isStaff && (a.Status is Web_Admin_Booking_App.Models.AppointmentStatus.Pending
                                        or Web_Admin_Booking_App.Models.AppointmentStatus.Confirmed
                                        or Web_Admin_Booking_App.Models.AppointmentStatus.Upcoming
                                        or Web_Admin_Booking_App.Models.AppointmentStatus.InProgress))
                                    {
                                        <form asp-controller="Appointments" asp-action="MarkCompleted" asp-route-id="@a.DocumentId" method="post" onsubmit="return confirm('Chuyển lịch hẹn này sang đã khám?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-primary">Đã khám</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const container = document.getElementById('doctorScheduleContainer');
            const buttons = document.querySelectorAll('[data-week-offset]');
            if (!container || buttons.length === 0) return;

            const baseUrl = container.dataset.scheduleUrl;
            const setActive = (offset) => {
                buttons.forEach(button => {
                    const isActive = button.dataset.weekOffset === offset;
                    button.classList.toggle('btn-primary', isActive);
                    button.classList.toggle('btn-outline-secondary', !isActive);
                });
            };

            buttons.forEach(button => {
                button.addEventListener('click', async () => {
                    const offset = button.dataset.weekOffset || '0';
                    setActive(offset);
                    container.classList.add('is-loading');

                    try {
                        const response = await fetch(`${baseUrl}?weekOffset=${encodeURIComponent(offset)}`, {
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });
                        const html = await response.text();
                        container.innerHTML = response.ok
                            ? html
                            : `<div class="alert alert-warning border-0 rounded-4 mb-0">${html}</div>`;
                    } catch {
                        container.innerHTML = '<div class="alert alert-warning border-0 rounded-4 mb-0">Không thể tải lịch tuần. Vui lòng thử lại sau.</div>';
                    } finally {
                        container.classList.remove('is-loading');
                    }
                });
            });
        })();
    </script>
}

@functions {
    private static string ValueOrDash(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static bool IsSelected(Web_Admin_Booking_App.Models.AppointmentListItemViewModel item, string? selectedId)
    {
        return !string.IsNullOrWhiteSpace(selectedId) &&
            (string.Equals(item.Id, selectedId, StringComparison.OrdinalIgnoreCase) ||
             string.Equals(item.DocumentId, selectedId, StringComparison.OrdinalIgnoreCase) ||
             string.Equals(item.AppointmentCode, selectedId, StringComparison.OrdinalIgnoreCase));
    }

    private static string StatusText(Web_Admin_Booking_App.Models.AppointmentStatus status) => status switch
    {
        Web_Admin_Booking_App.Models.AppointmentStatus.Pending => "Chờ xác nhận",
        Web_Admin_Booking_App.Models.AppointmentStatus.Confirmed => "Đã xác nhận",
        Web_Admin_Booking_App.Models.AppointmentStatus.Upcoming => "Sắp tới",
        Web_Admin_Booking_App.Models.AppointmentStatus.InProgress => "Đang khám",
        Web_Admin_Booking_App.Models.AppointmentStatus.Completed => "Đã khám",
        Web_Admin_Booking_App.Models.AppointmentStatus.CancelRequested => "Chờ duyệt hủy",
        Web_Admin_Booking_App.Models.AppointmentStatus.Cancelled => "Đã hủy",
        Web_Admin_Booking_App.Models.AppointmentStatus.NoShow => "Không đến",
        _ => "-"
    };

    private static string BadgeFor(Web_Admin_Booking_App.Models.AppointmentStatus status) => status switch
    {
        Web_Admin_Booking_App.Models.AppointmentStatus.Pending => "admin-badge--muted",
        Web_Admin_Booking_App.Models.AppointmentStatus.Confirmed => "admin-badge--info",
        Web_Admin_Booking_App.Models.AppointmentStatus.Upcoming => "admin-badge--info",
        Web_Admin_Booking_App.Models.AppointmentStatus.InProgress => "admin-badge--warning",
        Web_Admin_Booking_App.Models.AppointmentStatus.Completed => "admin-badge--success",
        Web_Admin_Booking_App.Models.AppointmentStatus.CancelRequested => "admin-badge--warning",
        Web_Admin_Booking_App.Models.AppointmentStatus.Cancelled => "admin-badge--danger",
        Web_Admin_Booking_App.Models.AppointmentStatus.NoShow => "admin-badge--muted",
        _ => "admin-badge--muted"
    };
}
