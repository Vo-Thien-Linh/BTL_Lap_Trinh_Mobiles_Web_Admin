@model IReadOnlyList<Web_Admin_Booking_App.Models.AppointmentListItemViewModel>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Lịch hẹn";

    var today = DateTime.Today;
    var total = Model.Count;
    var todayCount = Model.Count(x => x.ScheduledAt.Date == today);
    var pendingCount = Model.Count(x => x.Status == Web_Admin_Booking_App.Models.AppointmentStatus.Pending);
    var cancelRequestedCount = Model.Count(x => x.Status == Web_Admin_Booking_App.Models.AppointmentStatus.CancelRequested);
    var statusFilter = ViewData["StatusFilter"]?.ToString();
}

<div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-3">
    <div>
        <h1 class="h4 fw-bold mb-1">Quản lý lịch hẹn</h1>
        <div class="text-secondary">Theo dõi lịch khám, bệnh nhân, bác sĩ phụ trách và trạng thái xử lý.</div>
    </div>
    <a class="btn btn-primary" asp-controller="Appointments" asp-action="Create">Tạo lịch hẹn</a>
</div>

@if (TempData["InfoMessage"] is string infoMessage)
{
    <div class="alert alert-info">@infoMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="row g-3 mb-3">
    <div class="col-sm-6 col-xl-3">
        <div class="card panel-card h-100">
            <div class="card-body">
                <div class="text-secondary small">Tổng lịch hẹn</div>
                <div class="fs-4 fw-bold">@total</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card panel-card h-100">
            <div class="card-body">
                <div class="text-secondary small">Hôm nay</div>
                <div class="fs-4 fw-bold">@todayCount</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card panel-card h-100">
            <div class="card-body">
                <div class="text-secondary small">Chờ xác nhận</div>
                <div class="fs-4 fw-bold">@pendingCount</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card panel-card h-100">
            <div class="card-body">
                <div class="text-secondary small">Chờ duyệt hủy</div>
                <div class="fs-4 fw-bold">@cancelRequestedCount</div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a class="btn btn-sm @(string.IsNullOrWhiteSpace(statusFilter) ? "btn-primary" : "btn-outline-secondary")" asp-controller="Appointments" asp-action="Index">Tất cả</a>
    <a class="btn btn-sm @(statusFilter == nameof(Web_Admin_Booking_App.Models.AppointmentStatus.CancelRequested) ? "btn-primary" : "btn-outline-secondary")" asp-controller="Appointments" asp-action="Index" asp-route-statusFilter="@nameof(Web_Admin_Booking_App.Models.AppointmentStatus.CancelRequested)">Chờ duyệt hủy</a>
    <a class="btn btn-sm @(statusFilter == nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Pending) ? "btn-primary" : "btn-outline-secondary")" asp-controller="Appointments" asp-action="Index" asp-route-statusFilter="@nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Pending)">Chờ xác nhận</a>
    <a class="btn btn-sm @(statusFilter == nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Confirmed) ? "btn-primary" : "btn-outline-secondary")" asp-controller="Appointments" asp-action="Index" asp-route-statusFilter="@nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Confirmed)">Đã xác nhận</a>
    <a class="btn btn-sm @(statusFilter == nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Completed) ? "btn-primary" : "btn-outline-secondary")" asp-controller="Appointments" asp-action="Index" asp-route-statusFilter="@nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Completed)">Đã khám</a>
    <a class="btn btn-sm @(statusFilter == nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Cancelled) ? "btn-primary" : "btn-outline-secondary")" asp-controller="Appointments" asp-action="Index" asp-route-statusFilter="@nameof(Web_Admin_Booking_App.Models.AppointmentStatus.Cancelled)">Đã hủy</a>
</div>

<div class="card panel-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0 admin-table">
                <thead>
                    <tr class="text-secondary">
                        <th style="min-width: 260px;">Bệnh nhân</th>
                        <th style="min-width: 240px;">Bác sĩ phụ trách</th>
                        <th style="min-width: 170px;">Thời gian</th>
                        <th style="min-width: 220px;">Nội dung khám</th>
                        <th style="min-width: 170px;">Chi phí</th>
                        <th style="min-width: 170px;">Trạng thái</th>
                        <th style="min-width: 150px;" class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-secondary py-5">Chưa có lịch hẹn nào.</td>
                    </tr>
                }
                else
                {
                    foreach (var a in Model)
                    {
                        <tr>
                            <td>
                                <div class="person-cell">
                                    <div class="avatar">@Initials(a.PatientName)</div>
                                    <div>
                                        <div class="fw-semibold">@ValueOrDash(a.PatientName)</div>
                                        <div class="text-secondary small">@ValueOrDash(a.PatientPhone)</div>
                                        <div class="text-secondary small">@ValueOrDash(a.PatientEmail)</div>
                                        @if (!string.IsNullOrWhiteSpace(a.ScheduleId))
                                        {
                                            <div class="text-secondary small">Mã ca: @a.ScheduleId</div>
                                        }
                                        <div class="text-secondary small">Mã lịch: @ValueOrDash(a.AppointmentCode)</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="fw-semibold">@ValueOrDash(a.DoctorName)</div>
                                <div class="text-secondary small">@ValueOrDash(a.SpecialtyName)</div>
                                <div class="text-secondary small">@ValueOrDash(a.DoctorPhone)</div>
                                <div class="text-secondary small">@ValueOrDash(a.DoctorEmail)</div>
                            </td>
                            <td>
                                <div class="fw-semibold">@a.ScheduledAt.ToString("HH:mm")</div>
                                <div class="text-secondary small">@a.ScheduledAt.ToString("dd/MM/yyyy")</div>
                                @if (!string.IsNullOrWhiteSpace(a.Duration))
                                {
                                    <div class="text-secondary small">@a.Duration</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(a.RoomName))
                                {
                                    <div class="text-secondary small">Phòng: @a.RoomName</div>
                                }
                                @if (a.QueueNumber > 0)
                                {
                                    <div class="text-secondary small">Số thứ tự: @a.QueueNumber</div>
                                }
                            </td>
                            <td>
                                <div>@ValueOrDash(a.PatientNote)</div>
                                @if (!string.IsNullOrWhiteSpace(a.AppointmentType))
                                {
                                    <div class="text-secondary small">@a.AppointmentType</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(a.CancelReason))
                                {
                                    <div class="text-danger small">Lý do hủy: @a.CancelReason</div>
                                }
                                @if (a.CancelRequestedAt.HasValue)
                                {
                                    <div class="text-warning small">Yêu cầu hủy: @a.CancelRequestedAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                                }
                            </td>
                            <td>
                                <div class="fw-semibold">@ValueOrDash(a.ConsultationFee)</div>
                                <div class="text-secondary small">@ValueOrDash(a.PaymentStatus)</div>
                            </td>
                            <td>
                                <span class="badge @BadgeFor(a.Status)">@StatusText(a.Status)</span>
                                @if (a.UpdatedAt.HasValue)
                                {
                                    <div class="text-secondary small mt-1">Cập nhật: @a.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                                }
                            </td>
                            <td class="text-end">
                                @if (a.Status == Web_Admin_Booking_App.Models.AppointmentStatus.CancelRequested)
                                {
                                    <form asp-controller="Appointments" asp-action="ApproveCancel" asp-route-id="@a.DocumentId" method="post" onsubmit="return confirm('Duyệt hủy lịch này và trả lại slot cho ca làm việc?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">Duyệt hủy</button>
                                    </form>
                                }
                                else if (a.Status is Web_Admin_Booking_App.Models.AppointmentStatus.Pending
                                    or Web_Admin_Booking_App.Models.AppointmentStatus.Confirmed
                                    or Web_Admin_Booking_App.Models.AppointmentStatus.Upcoming
                                    or Web_Admin_Booking_App.Models.AppointmentStatus.InProgress)
                                {
                                    <form asp-controller="Appointments" asp-action="MarkCompleted" asp-route-id="@a.DocumentId" method="post" onsubmit="return confirm('Chuyển lịch hẹn này sang đã khám?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success">Đã khám</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-secondary small">-</span>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@functions {
    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0) return "";
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpperInvariant();
        return parts[0].Substring(0, 1).ToUpperInvariant() + parts[^1].Substring(0, 1).ToUpperInvariant();
    }

    private static string ValueOrDash(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string StatusText(Web_Admin_Booking_App.Models.AppointmentStatus status) => status switch
    {
        Web_Admin_Booking_App.Models.AppointmentStatus.Pending => "Chờ xác nhận",
        Web_Admin_Booking_App.Models.AppointmentStatus.Confirmed => "Đã xác nhận",
        Web_Admin_Booking_App.Models.AppointmentStatus.Upcoming => "Sắp đến",
        Web_Admin_Booking_App.Models.AppointmentStatus.InProgress => "Đang khám",
        Web_Admin_Booking_App.Models.AppointmentStatus.Completed => "Đã khám",
        Web_Admin_Booking_App.Models.AppointmentStatus.CancelRequested => "Chờ duyệt hủy",
        Web_Admin_Booking_App.Models.AppointmentStatus.Cancelled => "Đã hủy",
        Web_Admin_Booking_App.Models.AppointmentStatus.NoShow => "Không đến",
        _ => "-"
    };

    private static string BadgeFor(Web_Admin_Booking_App.Models.AppointmentStatus status) => status switch
    {
        Web_Admin_Booking_App.Models.AppointmentStatus.Pending => "text-bg-secondary",
        Web_Admin_Booking_App.Models.AppointmentStatus.Confirmed => "text-bg-info",
        Web_Admin_Booking_App.Models.AppointmentStatus.Upcoming => "text-bg-primary",
        Web_Admin_Booking_App.Models.AppointmentStatus.InProgress => "text-bg-warning",
        Web_Admin_Booking_App.Models.AppointmentStatus.Completed => "text-bg-success",
        Web_Admin_Booking_App.Models.AppointmentStatus.CancelRequested => "text-bg-warning",
        Web_Admin_Booking_App.Models.AppointmentStatus.Cancelled => "text-bg-danger",
        Web_Admin_Booking_App.Models.AppointmentStatus.NoShow => "text-bg-dark",
        _ => "text-bg-light"
    };
}
