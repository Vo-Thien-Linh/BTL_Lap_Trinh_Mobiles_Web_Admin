@model IReadOnlyList<Web_Admin_Booking_App.Models.DoctorListItemViewModel>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Bác sĩ";
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <div class="fw-bold fs-5">Danh sách bác sĩ</div>
        <div class="text-secondary">Quản lý thông tin và trạng thái làm việc</div>
    </div>
    <a class="btn btn-primary" asp-controller="Doctors" asp-action="Create">Thêm bác sĩ</a>
</div>

<div class="card panel-card">
    <div class="card-body">
        <div class="row g-2 align-items-center">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white" aria-hidden="true">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5" />
                            <path d="M11.2 11.2L14.5 14.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                    </span>
                    <input class="form-control" type="search" placeholder="Tìm theo tên, email, số điện thoại, chuyên khoa..." />
                </div>
            </div>
            <div class="col-md-6 text-md-end">
                <span class="text-secondary small">Tổng: @Model.Count bác sĩ</span>
            </div>
        </div>

        <div class="table-responsive mt-3">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr class="text-secondary">
                        <th style="min-width: 260px;">Tài khoản</th>
                        <th style="min-width: 220px;">Hồ sơ bác sĩ</th>
                        <th style="min-width: 180px;">Hành nghề</th>
                        <th>Phí khám</th>
                        <th style="min-width: 160px;">Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var d in Model)
                {
                    <tr>
                        <td>
                            <div class="person-cell">
                                <div class="avatar">@Initials(d.FullName)</div>
                                <div>
                                    <div class="fw-semibold">@d.FullName</div>
                                    @if (!string.IsNullOrWhiteSpace(d.Email))
                                    {
                                        <div class="text-secondary small text-break">@d.Email</div>
                                    }
                                    <div class="text-secondary small">@(string.IsNullOrWhiteSpace(d.Phone) ? "Chưa có số điện thoại" : d.Phone)</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="fw-semibold">@(string.IsNullOrWhiteSpace(d.Department) ? "-" : d.Department)</div>
                            <div class="text-secondary small">@(string.IsNullOrWhiteSpace(d.Specialization) ? "Chưa có chuyên khoa" : d.Specialization)</div>
                            <div class="text-secondary small">Mã hồ sơ: #@d.DocumentId</div>
                        </td>
                        <td>
                            <div>@(string.IsNullOrWhiteSpace(d.LicenseNumber) ? "-" : d.LicenseNumber)</div>
                            <div class="text-secondary small">@(string.IsNullOrWhiteSpace(d.Degree) ? "Chưa có học vị" : d.Degree)</div>
                            <div class="text-secondary small">@(string.IsNullOrWhiteSpace(d.YearsOfExperience) ? "Chưa có kinh nghiệm" : d.YearsOfExperience)</div>
                        </td>
                        <td class="text-secondary">@(string.IsNullOrWhiteSpace(d.ConsultationFee) ? "-" : d.ConsultationFee)</td>
                        <td>
                            <div><span class="badge @StatusBadge(d.UserStatus)">@ValueOrDash(d.UserStatus)</span></div>
                            <div class="mt-1"><span class="badge @StatusBadge(d.VerificationStatus)">@ValueOrDash(d.VerificationStatus)</span></div>
                            <div class="text-secondary small mt-1">Hoạt động: @(d.IsActive == true ? "Có" : "Không")</div>
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-light" asp-controller="Doctors" asp-action="Details" asp-route-id="@d.DocumentId">Xem</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@functions {
    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0) return "";
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpperInvariant();
        var first = parts[0].Substring(0, 1).ToUpperInvariant();
        var last = parts[^1].Substring(0, 1).ToUpperInvariant();
        return first + last;
    }

    private static string ValueOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string StatusBadge(string? status) => status switch
    {
        "Đang hoạt động" or "Đã duyệt" => "text-bg-primary",
        "Chờ kích hoạt" or "Chờ duyệt" or "Bản nháp" => "text-bg-warning",
        "Đã khóa" or "Từ chối" => "text-bg-secondary",
        _ => "text-bg-light"
    };
}
