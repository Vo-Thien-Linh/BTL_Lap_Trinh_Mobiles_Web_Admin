@model Web_Admin_Booking_App.Models.DoctorDetailsViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết bác sĩ";
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <div class="fw-bold fs-5">@Model.FullName</div>
        <div class="text-secondary">
            @if (!string.IsNullOrWhiteSpace(Model.Degree))
            {
                <span>@Model.Degree</span>
                <span> - </span>
            }
            <span>@ValueOrDash(Model.Specialization ?? Model.Department)</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <form asp-controller="Doctors" asp-action="Approve" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.DocumentId" />
            <button class="btn btn-success" type="submit">Duyệt hồ sơ</button>
        </form>
        <button class="btn btn-outline-danger" type="button" data-bs-toggle="collapse" data-bs-target="#rejectForm">
            Từ chối
        </button>
        <a class="btn btn-light" asp-controller="Doctors" asp-action="Index">Quay lại</a>
    </div>
</div>

@if (TempData["InfoMessage"] is string message)
{
    <div class="alert alert-info">@message</div>
}

<div class="collapse mb-3" id="rejectForm">
    <div class="card panel-card">
        <div class="card-body">
            <form asp-controller="Doctors" asp-action="Reject" method="post" class="row g-2 align-items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.DocumentId" />
                <div class="col-md-9">
                    <label class="form-label">Lý do từ chối</label>
                    <input class="form-control" name="rejectReason" placeholder="VD: Chứng chỉ hành nghề chưa hợp lệ" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-danger w-100" type="submit">Xác nhận từ chối</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card panel-card">
            <div class="card-body">
                <div class="fw-bold mb-2">Hồ sơ</div>
                <div class="d-grid gap-2">
                    @FieldRows(Model.ProfileFields)
                </div>
            </div>
        </div>

        <div class="card panel-card mt-3">
            <div class="card-body">
                <div class="fw-bold mb-2">Liên hệ</div>
                <div class="d-grid gap-2">
                    @FieldRows(Model.ContactFields)
                </div>
            </div>
        </div>

        <div class="card panel-card mt-3">
            <div class="card-body">
                <div class="fw-bold mb-2">Quản trị</div>
                <div class="d-grid gap-2">
                    @FieldRows(Model.AdminFields)
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card panel-card">
            <div class="card-body">
                <div class="fw-bold mb-2">Chuyên môn</div>
                <div class="row g-3">
                    @FieldTiles(Model.ProfessionalFields)
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    private static string ValueOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static Microsoft.AspNetCore.Html.IHtmlContent FieldRows(
        IReadOnlyList<Web_Admin_Booking_App.Models.DoctorDetailFieldViewModel> fields)
    {
        if (fields.Count == 0)
        {
            return new Microsoft.AspNetCore.Html.HtmlString("<div class=\"text-secondary\">Chưa có thông tin.</div>");
        }

        var rows = string.Join("", fields.Select(field =>
            $"<div class=\"d-flex justify-content-between gap-3\"><span class=\"text-secondary\">{Encode(field.Label)}</span><span class=\"fw-semibold text-end text-break\">{Encode(field.Value)}</span></div>"));
        return new Microsoft.AspNetCore.Html.HtmlString(rows);
    }

    private static Microsoft.AspNetCore.Html.IHtmlContent FieldTiles(
        IReadOnlyList<Web_Admin_Booking_App.Models.DoctorDetailFieldViewModel> fields)
    {
        if (fields.Count == 0)
        {
            return new Microsoft.AspNetCore.Html.HtmlString("<div class=\"col-12 text-secondary\">Chưa có thông tin.</div>");
        }

        var tiles = string.Join("", fields.Select(field =>
            $"<div class=\"col-md-6\"><div class=\"text-secondary small\">{Encode(field.Label)}</div><div class=\"fw-semibold text-break\">{Encode(field.Value)}</div></div>"));
        return new Microsoft.AspNetCore.Html.HtmlString(tiles);
    }

    private static string Encode(string value) => System.Net.WebUtility.HtmlEncode(value);
}
