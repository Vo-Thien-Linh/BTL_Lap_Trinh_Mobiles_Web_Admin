@model Web_Admin_Booking_App.Models.DoctorDetailsViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết bác sĩ";
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <div class="fw-bold fs-5">@Model.FullName</div>
        <div class="text-secondary">@Model.Department</div>
    </div>
    <a class="btn btn-light" asp-controller="Doctors" asp-action="Index">Quay lại</a>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card panel-card">
            <div class="card-body">
                <div class="fw-bold mb-2">Thông tin</div>
                <div class="d-grid gap-2">
                    <div class="d-flex justify-content-between"><span class="text-secondary">Mã</span><span class="fw-semibold">#@Model.Id</span></div>
                    <div class="d-flex justify-content-between"><span class="text-secondary">Trạng thái</span><span class="badge text-bg-primary">@Model.Status</span></div>
                    <div class="d-flex justify-content-between"><span class="text-secondary">Số điện thoại</span><span class="fw-semibold">@Model.Phone</span></div>
                    <div class="d-flex justify-content-between"><span class="text-secondary">Email</span><span class="fw-semibold">@(Model.Email ?? "-")</span></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card panel-card">
            <div class="card-body">
                <div class="fw-bold mb-2">Ghi chú</div>
                <div class="text-secondary">Trang này đang dùng dữ liệu mẫu. Có thể nối DB/API để hiển thị lịch làm việc, lịch hẹn của bác sĩ…</div>
            </div>
        </div>
    </div>
</div>
