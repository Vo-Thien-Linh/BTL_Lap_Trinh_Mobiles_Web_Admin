@model Web_Admin_Booking_App.Models.DoctorCreateViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm bác sĩ";
    ViewData["PageTitle"] = "Thêm bác sĩ";
}

<section class="admin-form-page">
    <div class="admin-page-header admin-page-header--compact">
        <div>
            <div class="admin-page-kicker">Bác sĩ</div>
            <h1 class="admin-page-title">Thêm bác sĩ mới</h1>
            <p class="admin-page-subtitle">Tạo tài khoản đăng nhập và hồ sơ chuyên môn cho bác sĩ.</p>
        </div>
        <a class="admin-action-btn" asp-controller="Doctors" asp-action="Index">Quay lại</a>
    </div>

    <div class="form-stepper" aria-label="Các bước nhập hồ sơ bác sĩ">
        <div class="form-stepper__item">
            <span class="form-stepper__number">1</span>
            <span class="form-stepper__text">
                <span class="form-stepper__title">Tài khoản</span>
                <span class="form-stepper__subtitle">Đăng nhập, liên hệ, định danh</span>
            </span>
        </div>
        <div class="form-stepper__item">
            <span class="form-stepper__number">2</span>
            <span class="form-stepper__text">
                <span class="form-stepper__title">Chuyên môn</span>
                <span class="form-stepper__subtitle">Khoa, chứng chỉ, kinh nghiệm</span>
            </span>
        </div>
        <div class="form-stepper__item">
            <span class="form-stepper__number">3</span>
            <span class="form-stepper__text">
                <span class="form-stepper__title">Quản trị</span>
                <span class="form-stepper__subtitle">Duyệt hồ sơ và hiển thị</span>
            </span>
        </div>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data" id="doctorCreateForm">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-4"></div>

        <div class="admin-form-shell">
            <div class="admin-form-main">
                <section class="admin-form-card section-accent--account">
                    <div class="admin-form-card__header">
                        <h2 class="admin-form-card__title">Thông tin tài khoản</h2>
                        <p class="admin-form-card__subtitle">Email và mật khẩu dùng để bác sĩ đăng nhập ứng dụng.</p>
                    </div>
                    <div class="admin-form-card__body">
                        <div class="admin-form-grid">
                            <div>
                                <label asp-for="FullName" class="form-label"></label>
                                <input asp-for="FullName" class="form-control" placeholder="VD: BS. Nguyễn Văn A" data-preview-name />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>
                            <div>
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control" placeholder="VD: doctor@hospital.vn" data-preview-email />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div>
                                <label asp-for="Password" class="form-label"></label>
                                <input asp-for="Password" class="form-control" autocomplete="new-password" placeholder="Tối thiểu 6 ký tự" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                            <div>
                                <label asp-for="Phone" class="form-label"></label>
                                <input asp-for="Phone" class="form-control" inputmode="numeric" maxlength="10" placeholder="VD: 0901234567" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                            <div>
                                <label asp-for="Cccd" class="form-label"></label>
                                <input asp-for="Cccd" class="form-control" inputmode="numeric" maxlength="12" placeholder="12 chữ số" />
                                <span asp-validation-for="Cccd" class="text-danger"></span>
                            </div>
                            <div>
                                <label asp-for="AvatarFile" class="form-label"></label>
                                <input asp-for="AvatarFile" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                                <span asp-validation-for="AvatarFile" class="text-danger"></span>
                            </div>
                            <div>
                                <label asp-for="Gender" class="form-label"></label>
                                <select asp-for="Gender" class="form-select">
                                    <option value="">Chưa chọn</option>
                                    <option value="male">Nam</option>
                                    <option value="female">Nữ</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger"></span>
                            </div>
                            <div>
                                <label asp-for="DateOfBirth" class="form-label"></label>
                                <input asp-for="DateOfBirth" class="form-control" />
                                <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                            </div>
                            <div>
                                <label asp-for="UserStatus" class="form-label"></label>
                                <select asp-for="UserStatus" class="form-select">
                                    <option value="pending">Chờ kích hoạt</option>
                                    <option value="active">Đang hoạt động</option>
                                    <option value="blocked">Đã khóa</option>
                                </select>
                                <span asp-validation-for="UserStatus" class="text-danger"></span>
                            </div>
                            <div class="d-flex align-items-center">
                                <div class="form-check">
                                    <input asp-for="EmailVerified" class="form-check-input" />
                                    <label asp-for="EmailVerified" class="form-check-label"></label>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="admin-form-card section-accent--professional">
                    <div class="admin-form-card__header">
                        <h2 class="admin-form-card__title">Hồ sơ chuyên môn</h2>
                        <p class="admin-form-card__subtitle">Mã bác sĩ và mã tài khoản sẽ được hệ thống tạo tự động.</p>
                    </div>
                    <div class="admin-form-card__body">
                        <div class="admin-form-grid">
                            <div>
                                <label asp-for="DepartmentId" class="form-label"></label>
                                <select asp-for="DepartmentId" class="form-select">
                                    <option value="">Chọn khoa</option>
                                    @foreach (var department in Model.Departments)
                                    {
                                        <option value="@department.Value">@department.Text</option>
                                    }
                                </select>
                                <span asp-validation-for="DepartmentId" class="text-danger"></span>
                            </div>
                            <div>
                                <label asp-for="Specialization" class="form-label"></label>
                                <input asp-for="Specialization" class="form-control" placeholder="VD: Nội tổng quát" />
                                <span asp-validation-for="Specialization" class="text-danger"></span>
                            </div>
                            <div>
                                <label asp-for="LicenseNumber" class="form-label"></label>
                                <input asp-for="LicenseNumber" class="form-control" placeholder="VD: CCHN-0001" />
                                <span asp-validation-for="LicenseNumber" class="text-danger"></span>
                            </div>
                            <div>
                                <label asp-for="Degree" class="form-label"></label>
                                <input asp-for="Degree" class="form-control" placeholder="VD: Thạc sĩ, Bác sĩ CKI" />
                                <span asp-validation-for="Degree" class="text-danger"></span>
                            </div>
                            <div>
                                <label asp-for="YearsOfExperience" class="form-label"></label>
                                <input asp-for="YearsOfExperience" class="form-control" type="number" min="0" max="80" />
                                <span asp-validation-for="YearsOfExperience" class="text-danger"></span>
                            </div>
                            <div>
                                <label asp-for="ConsultationFee" class="form-label"></label>
                                <input asp-for="ConsultationFee" class="form-control js-money-input" type="text" inputmode="numeric" placeholder="VD: 300.000" />
                                <span asp-validation-for="ConsultationFee" class="text-danger"></span>
                            </div>
                            <div class="is-full">
                                <label asp-for="Biography" class="form-label"></label>
                                <textarea asp-for="Biography" class="form-control" rows="4" placeholder="Tóm tắt chuyên môn, kinh nghiệm và phạm vi điều trị"></textarea>
                                <span asp-validation-for="Biography" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="admin-form-card section-accent--admin">
                    <div class="admin-form-card__header">
                        <h2 class="admin-form-card__title">Thiết lập quản trị</h2>
                        <p class="admin-form-card__subtitle">Trạng thái duyệt và hiển thị của hồ sơ bác sĩ.</p>
                    </div>
                    <div class="admin-form-card__body">
                        <div class="admin-form-grid">
                            <div>
                                <label asp-for="VerificationStatus" class="form-label"></label>
                                <select asp-for="VerificationStatus" class="form-select">
                                    <option value="pending">Chờ duyệt</option>
                                    <option value="verified">Đã xác minh</option>
                                    <option value="rejected">Từ chối</option>
                                </select>
                                <span asp-validation-for="VerificationStatus" class="text-danger"></span>
                            </div>
                            <div class="d-flex align-items-center">
                                <div class="form-check">
                                    <input asp-for="IsActive" class="form-check-input" />
                                    <label asp-for="IsActive" class="form-check-label"></label>
                                </div>
                            </div>
                            <div class="d-flex align-items-center">
                                <div class="form-check">
                                    <input asp-for="IsFeatured" class="form-check-input" />
                                    <label asp-for="IsFeatured" class="form-check-label"></label>
                                </div>
                            </div>
                            <div>
                                <label class="form-label" for="FeaturedRank">Thứ hạng nổi bật</label>
                                <input asp-for="FeaturedRank" class="form-control" type="number" min="1" max="999" placeholder="VD: 1" />
                                <span asp-validation-for="FeaturedRank" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </section>

                <div class="admin-form-actions">
                    <a class="btn btn-outline-secondary px-4" asp-controller="Doctors" asp-action="Index">Hủy</a>
                    <button type="submit" class="btn btn-primary px-4">Tạo mới bác sĩ</button>
                </div>
            </div>

            <aside class="admin-form-aside">
                <div class="admin-help-card compact-help-card">
                    <div class="admin-help-card__avatar" data-preview-avatar>BS</div>
                    <h2 class="h5 fw-bold mb-1" data-preview-title>Hồ sơ bác sĩ</h2>
                    <div class="text-secondary text-break-soft" data-preview-subtitle>Email đăng nhập</div>
                    <ul class="admin-help-list compact-tip-list">
                        <li>Email dùng để đăng nhập ứng dụng.</li>
                        <li>Mã hồ sơ được tạo tự động.</li>
                        <li>Bác sĩ cần được duyệt trước khi hiển thị.</li>
                        <li>Ảnh đại diện nên rõ mặt.</li>
                    </ul>
                </div>
            </aside>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const formatMoney = value => {
                const digits = (value || "").replace(/\D/g, "");
                return digits.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
            };

            document.querySelectorAll(".js-money-input").forEach(input => {
                input.value = formatMoney(input.value);
                input.addEventListener("input", () => input.value = formatMoney(input.value));
                input.form?.addEventListener("submit", () => input.value = (input.value || "").replace(/\D/g, ""));
            });

            const featuredCheckbox = document.querySelector("#IsFeatured");
            const featuredRank = document.querySelector("#FeaturedRank");
            const syncFeaturedRank = () => {
                if (!featuredCheckbox || !featuredRank) return;
                featuredRank.disabled = !featuredCheckbox.checked;
                if (!featuredCheckbox.checked) featuredRank.value = "";
            };
            featuredCheckbox?.addEventListener("change", syncFeaturedRank);
            syncFeaturedRank();

            const nameInput = document.querySelector("[data-preview-name]");
            const emailInput = document.querySelector("[data-preview-email]");
            const avatar = document.querySelector("[data-preview-avatar]");
            const title = document.querySelector("[data-preview-title]");
            const subtitle = document.querySelector("[data-preview-subtitle]");
            const initials = value => {
                const parts = (value || "").trim().split(/\s+/).filter(Boolean);
                if (parts.length === 0) return "BS";
                if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
                return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
            };
            const syncPreview = () => {
                if (avatar) avatar.textContent = initials(nameInput?.value);
                if (title) title.textContent = nameInput?.value || "Hồ sơ bác sĩ";
                if (subtitle) subtitle.textContent = emailInput?.value || "Email đăng nhập";
            };
            nameInput?.addEventListener("input", syncPreview);
            emailInput?.addEventListener("input", syncPreview);
            syncPreview();
        })();
    </script>
}
