@model Web_Admin_Booking_App.Models.WorkShiftsIndexViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Cấu hình ca chuẩn";
    var previousWeek = Model.WeeklyTable.WeekStart.AddDays(-7);
    var nextWeek = Model.WeeklyTable.WeekStart.AddDays(7);
}

<div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-3">
    <div>
        <h1 class="h4 fw-bold mb-1">Cấu hình ca chuẩn</h1>
        <div class="text-secondary">Theo dõi khung ca, phòng khám và lịch tuần. Phân công lịch bác sĩ hằng ngày do Staff xử lý tại màn Phân công lịch bác sĩ.</div>
    </div>
    <span class="badge text-bg-light border">Admin chỉ xem/cấu hình ca chuẩn</span>
</div>

@if (TempData["InfoMessage"] is string message)
{
    <div class="alert alert-info">@message</div>
}

<div class="row g-3 mb-3">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card"><div class="card-body"><div class="stat-card__label">Bác sĩ</div><div class="stat-card__value">@Model.TotalDoctorsLabel</div><div class="stat-card__hint text-secondary">@Model.RangeLabel</div></div></div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card"><div class="card-body"><div class="stat-card__label">Chưa phân</div><div class="stat-card__value">@Model.UnassignedCount.ToString("00") ca</div><div class="stat-card__hint text-secondary">Thiếu bác sĩ</div></div></div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card"><div class="card-body"><div class="stat-card__label">Tỷ lệ khả dụng</div><div class="stat-card__value">@Model.FillRatePercent.ToString("0.#")%</div><div class="stat-card__hint text-secondary">Trong tháng</div></div></div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card"><div class="card-body"><div class="stat-card__label">Trùng ca</div><div class="stat-card__value">@Model.ConflictCount.ToString("00") ca</div><div class="stat-card__hint text-secondary">Cần kiểm tra</div></div></div>
    </div>
</div>

<div class="card panel-card mb-3">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
            <div>
                <div class="fw-semibold text-uppercase">Lịch làm việc bác sĩ từ ngày @Model.WeeklyTable.WeekStart.ToString("dd/MM/yyyy") đến ngày @Model.WeeklyTable.WeekEnd.ToString("dd/MM/yyyy")</div>
                <div class="text-secondary small">Bảng tuần dùng để kiểm tra ca chuẩn và tình trạng phân bổ. Staff thực hiện phân công/sửa lịch chi tiết ở màn riêng.</div>
            </div>
            <div class="d-flex align-items-center flex-wrap gap-2">
                <div class="btn-group btn-group-sm" role="group" aria-label="Chọn tuần">
                    <a class="btn btn-outline-secondary" asp-controller="WorkShifts" asp-action="Index" asp-route-weekStart="@previousWeek.ToString("yyyy-MM-dd")">Tuần trước</a>
                    <a class="btn btn-outline-secondary" asp-controller="WorkShifts" asp-action="Index">Tuần này</a>
                    <a class="btn btn-outline-secondary" asp-controller="WorkShifts" asp-action="Index" asp-route-weekStart="@nextWeek.ToString("yyyy-MM-dd")">Tuần sau</a>
                </div>
                <div class="admin-legend">
                    <span class="admin-legend__item"><span class="admin-legend__dot admin-legend__dot--morning"></span>Ca sáng</span>
                    <span class="admin-legend__item"><span class="admin-legend__dot admin-legend__dot--afternoon"></span>Ca chiều</span>
                </div>
            </div>
        </div>

        <div class="table-responsive mt-3">
            <table class="table table-bordered align-middle admin-week-table mb-0">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 54px;">TT</th>
                        <th style="width: 260px; min-width: 260px;">Phòng khám</th>
                        @foreach (var day in Model.WeeklyTable.Days)
                        {
                            <th class="text-center @(day.IsToday ? "text-danger" : "")" style="min-width: 150px;">@day.Label</th>
                        }
                    </tr>
                </thead>
                <tbody>
                @if (Model.WeeklyTable.Rows.Count == 0)
                {
                    <tr><td colspan="9" class="text-center text-secondary py-4">Chưa có lịch làm việc trong tuần này.</td></tr>
                }
                else
                {
                    foreach (var row in Model.WeeklyTable.Rows)
                    {
                        <tr>
                            <td class="text-center">@row.Index</td>
                            <td class="fw-semibold text-center">
                                <div>@row.DepartmentName.ToUpperInvariant()</div>
                                <div class="small text-secondary">(@row.LocationLabel)</div>
                            </td>
                            @foreach (var day in Model.WeeklyTable.Days)
                            {
                                var items = row.ItemsByDate.TryGetValue(day.Date, out var found)
                                    ? found
                                    : Array.Empty<Web_Admin_Booking_App.Models.WeeklyScheduleCellItemViewModel>();
                                <td class="admin-week-cell @(items.Count == 0 ? "is-empty" : "")">
                                    @if (items.Count == 0)
                                    {
                                        <span class="text-secondary small">-</span>
                                    }
                                    else
                                    {
                                        foreach (var item in items)
                                        {
                                            <div class="admin-week-shift @WeekShiftClass(item)">
                                                <div class="fw-bold">@item.DoctorName</div>
                                                <div class="small">@ValueOrDash(item.ShiftName)</div>
                                                @if (!string.IsNullOrWhiteSpace(item.ShiftTime))
                                                {
                                                    <div class="small">@item.ShiftTime</div>
                                                }
                                                <div class="small text-secondary">Còn @item.AvailableSlots/@item.MaxSlots slot</div>
                                            </div>
                                        }
                                    }
                                </td>
                            }
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="alert alert-light border mb-0">
    Staff phân công lịch bác sĩ tại <a asp-controller="DoctorSchedules" asp-action="Index">Phân công lịch bác sĩ</a>. Màn này không dùng để phân công bác sĩ theo ngày.
</div>

@functions {
    private static string WeekShiftClass(Web_Admin_Booking_App.Models.WeeklyScheduleCellItemViewModel item)
    {
        if (!item.IsActive) return "is-off";
        return item.ShiftType == Web_Admin_Booking_App.Models.ShiftType.Afternoon ? "is-afternoon" : "is-morning";
    }

    private static string ValueOrDash(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;
}
