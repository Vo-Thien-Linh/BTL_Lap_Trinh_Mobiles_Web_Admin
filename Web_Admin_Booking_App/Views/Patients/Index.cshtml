@model Web_Admin_Booking_App.Models.PatientIndexViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý bệnh nhân";
}

<section class="page-hero mb-4">
    <div>
        <div class="eyebrow">Hồ sơ bệnh nhân</div>
        <h1>Quản lý bệnh nhân</h1>
        <p>Tra cứu hồ sơ, liên hệ, BHYT và trạng thái tài khoản bệnh nhân.</p>
    </div>
</section>

<div class="admin-stat-grid mb-4">
    <div class="admin-stat-card">
        <span class="admin-stat-card__label">Tổng hồ sơ</span>
        <strong>@Model.TotalCount</strong>
        <small>Tất cả bệnh nhân phù hợp bộ lọc</small>
    </div>
    <div class="admin-stat-card">
        <span class="admin-stat-card__label">Đang hoạt động</span>
        <strong>@Model.ActiveCount</strong>
        <small>Tài khoản có thể sử dụng hệ thống</small>
    </div>
    <div class="admin-stat-card">
        <span class="admin-stat-card__label">Chờ xác minh BHYT</span>
        <strong>@Model.PendingInsuranceCount</strong>
        <small>Hồ sơ cần nhân viên xét duyệt</small>
    </div>
    <div class="admin-stat-card">
        <span class="admin-stat-card__label">Đã duyệt BHYT</span>
        <strong>@Model.ApprovedInsuranceCount</strong>
        <small>Có thể áp dụng khi đủ điều kiện thanh toán</small>
    </div>
</div>

<form id="patientFilterForm" asp-controller="Patients" asp-action="Index" method="get" class="filter-toolbar mb-3">
    <div class="filter-search">
        <span>⌕</span>
        <input name="search" value="@Model.Search" class="form-control" autocomplete="off" placeholder="Tìm theo mã bệnh nhân, họ tên, SĐT, email, CCCD, mã BHYT..." />
    </div>
    <select name="genderFilter" class="form-select filter-select">
        <option value="">Tất cả giới tính</option>
        <option value="Male" selected="@(Model.GenderFilter == "Male")">Nam</option>
        <option value="Female" selected="@(Model.GenderFilter == "Female")">Nữ</option>
        <option value="Other" selected="@(Model.GenderFilter == "Other")">Khác</option>
        <option value="Unknown" selected="@(Model.GenderFilter == "Unknown")">Chưa cập nhật</option>
    </select>
    <select name="statusFilter" class="form-select filter-select">
        <option value="">Tất cả trạng thái</option>
        <option value="Active" selected="@(Model.StatusFilter == "Active")">Đang hoạt động</option>
        <option value="Inactive" selected="@(Model.StatusFilter == "Inactive")">Tạm ngưng</option>
        <option value="Blocked" selected="@(Model.StatusFilter == "Blocked")">Bị khóa</option>
    </select>
    <select name="insuranceFilter" class="form-select filter-select">
        <option value="">Tất cả BHYT</option>
        <option value="pending" selected="@(Model.InsuranceFilter == "pending")">Chờ xác minh</option>
        <option value="approved" selected="@(Model.InsuranceFilter == "approved")">Đã duyệt</option>
        <option value="rejected" selected="@(Model.InsuranceFilter == "rejected")">Từ chối</option>
        <option value="expired" selected="@(Model.InsuranceFilter == "expired")">Hết hạn</option>
        <option value="missing" selected="@(Model.InsuranceFilter == "missing")">Chưa có</option>
    </select>
    <div class="filter-validation-message @(string.IsNullOrWhiteSpace(Model.FilterError) ? "" : "is-visible")" data-filter-error>
        @Model.FilterError
    </div>
</form>

<div id="patientResults">
    <partial name="_PatientTable" model="Model" />
</div>

@section Scripts {
    <script>
(() => {
    const form = document.getElementById('patientFilterForm');
    const target = document.getElementById('patientResults');
    if (!form || !target) return;

    let timer;
    const error = form.querySelector('[data-filter-error]');

    const setError = (message) => {
        if (!error) return;
        error.textContent = message || '';
        error.classList.toggle('is-visible', Boolean(message));
        form.querySelector('[name="search"]')?.classList.toggle('is-invalid', Boolean(message));
    };

    const validateFilters = () => {
        const search = form.querySelector('[name="search"]')?.value?.trim() || '';
        if (search.length > 100) return 'Từ khóa tìm kiếm không được vượt quá 100 ký tự.';
        return '';
    };

    const submitRealtime = () => {
        clearTimeout(timer);
        timer = setTimeout(async () => {
            const validationMessage = validateFilters();
            setError(validationMessage);
            if (validationMessage) return;

            const url = `${form.action}?${new URLSearchParams(new FormData(form)).toString()}`;
            target.classList.add('is-loading');
            const response = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            target.innerHTML = await response.text();
            target.classList.remove('is-loading');
            window.history.replaceState(null, '', url);
        }, 300);
    };

    form.querySelectorAll('input, select').forEach(el => {
        el.addEventListener('input', submitRealtime);
        el.addEventListener('change', submitRealtime);
    });
})();
    </script>
}
