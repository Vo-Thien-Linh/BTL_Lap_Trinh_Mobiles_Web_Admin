@model Web_Admin_Booking_App.Models.PatientDetailsViewModel
@using Web_Admin_Booking_App.Models
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết bệnh nhân";
}
@functions {
    string GenderText(Gender gender) => gender switch
    {
        Gender.Male => "Nam",
        Gender.Female => "Nữ",
        Gender.Other => "Khác",
        _ => "Chưa cập nhật"
    };

    string StatusText(PatientStatus status) => status switch
    {
        PatientStatus.Inactive => "Tạm ngưng",
        PatientStatus.Blocked => "Bị khóa",
        _ => "Đang hoạt động"
    };

    string InsuranceStatusText(string? status) => status?.Trim().ToLowerInvariant() switch
    {
        "pending" => "Chờ duyệt",
        "approved" => "Đã duyệt",
        "rejected" => "Từ chối",
        "missing" or "" or null => "Chưa cập nhật",
        _ => status
    };
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
    <div>
        <div class="eyebrow">Hồ sơ bệnh nhân</div>
        <h1 class="page-title mb-1">@Model.FullName</h1>
        <p class="text-secondary mb-0">Mã bệnh nhân: @Model.Id</p>
    </div>
    <a class="btn btn-light" asp-controller="Patients" asp-action="Index">Quay lại danh sách</a>
</div>

<div class="patient-detail-grid">
    <aside class="profile-summary-card">
        <div class="avatar avatar-xl mx-auto">@Model.AvatarText</div>
        <h2>@Model.FullName</h2>
        <p>@(string.IsNullOrWhiteSpace(Model.Email) ? "Chưa có email" : Model.Email)</p>
        <span class="admin-pill admin-pill--active">@StatusText(Model.Status)</span>

        <div class="summary-divider"></div>

        <div class="summary-item"><span>BHYT</span><strong>@(string.IsNullOrWhiteSpace(Model.HealthInsuranceNumber) ? "Chưa cập nhật" : Model.HealthInsuranceNumber)</strong></div>
        <div class="summary-item"><span>Trạng thái BHYT</span><strong>@InsuranceStatusText(Model.HealthInsuranceStatus)</strong></div>
        <div class="summary-item"><span>Ngày tạo hồ sơ</span><strong>@(Model.CreatedAt?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</strong></div>
    </aside>

    <main class="detail-stack">
        <section class="card detail-card">
            <div class="detail-card__header">
                <h3>Thông tin cá nhân</h3>
                <span>Thông tin định danh và liên hệ</span>
            </div>
            <div class="info-grid">
                <div class="info-item"><span>Số điện thoại</span><strong>@Model.Phone</strong></div>
                <div class="info-item"><span>Email</span><strong>@(string.IsNullOrWhiteSpace(Model.Email) ? "Chưa cập nhật" : Model.Email)</strong></div>
                <div class="info-item"><span>CCCD</span><strong>@(string.IsNullOrWhiteSpace(Model.Cccd) ? "Chưa cập nhật" : Model.Cccd)</strong></div>
                <div class="info-item"><span>Giới tính</span><strong>@GenderText(Model.Gender)</strong></div>
                <div class="info-item"><span>Ngày sinh</span><strong>@(Model.Dob?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</strong></div>
                <div class="info-item"><span>Địa chỉ</span><strong>@Model.Address</strong></div>
            </div>
        </section>

        <section class="card detail-card">
            <div class="detail-card__header">
                <h3>Thông tin BHYT</h3>
                <span>Dữ liệu bảo hiểm người bệnh cung cấp</span>
            </div>
            <div class="info-grid">
                <div class="info-item"><span>Mã thẻ</span><strong>@(string.IsNullOrWhiteSpace(Model.HealthInsuranceNumber) ? "Chưa cập nhật" : Model.HealthInsuranceNumber)</strong></div>
                <div class="info-item"><span>Trạng thái</span><strong>@InsuranceStatusText(Model.HealthInsuranceStatus)</strong></div>
            </div>
            @if (string.Equals(Model.HealthInsuranceStatus, "pending", StringComparison.OrdinalIgnoreCase))
            {
                <div class="d-flex flex-wrap gap-2 mt-3 insurance-actions">
                    <form asp-controller="Patients" asp-action="UpdateInsuranceStatus" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="status" value="approved" />
                        <button type="submit" class="btn btn-success">Xác nhận</button>
                    </form>
                    <form asp-controller="Patients" asp-action="UpdateInsuranceStatus" method="post" class="d-flex flex-wrap gap-2" id="rejectInsuranceForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="status" value="rejected" />
                        <input name="rejectReason" class="form-control d-none" style="min-width: 260px;" placeholder="Lý do từ chối (có thể để trống)" />
                        <button type="button" class="btn btn-outline-danger" id="showRejectReason">Từ chối</button>
                    </form>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.HealthInsuranceRejectReason))
            {
                <div class="alert alert-warning mt-3 mb-0">Lý do từ chối: @Model.HealthInsuranceRejectReason</div>
            }
        </section>

        <section class="card detail-card">
            <div class="detail-card__header">
                <h3>Thông tin y tế</h3>
                <span>Dị ứng, bệnh nền và ghi chú chăm sóc</span>
            </div>
            <div class="info-grid">
                <div class="info-item"><span>Nhóm máu</span><strong>@(string.IsNullOrWhiteSpace(Model.BloodType) ? "Chưa cập nhật" : Model.BloodType)</strong></div>
                <div class="info-item"><span>Dị ứng</span><strong>@(string.IsNullOrWhiteSpace(Model.Allergy) ? "Không ghi nhận" : Model.Allergy)</strong></div>
                <div class="info-item"><span>Bệnh mạn tính</span><strong>@(string.IsNullOrWhiteSpace(Model.ChronicDisease) ? "Không ghi nhận" : Model.ChronicDisease)</strong></div>
                <div class="info-item"><span>Ghi chú</span><strong>@(string.IsNullOrWhiteSpace(Model.Notes) ? "Không có ghi chú" : Model.Notes)</strong></div>
            </div>
        </section>
    </main>
</div>

@section Scripts {
    <script>
(() => {
    const form = document.getElementById('rejectInsuranceForm');
    const input = form?.querySelector('[name="rejectReason"]');
    const button = document.getElementById('showRejectReason');
    if (!form || !input || !button) return;

    let readyToSubmit = false;
    button.addEventListener('click', () => {
        if (!readyToSubmit) {
            input.classList.remove('d-none');
            input.focus();
            button.textContent = 'Gửi từ chối';
            readyToSubmit = true;
            return;
        }

        form.submit();
    });
})();
    </script>
}
