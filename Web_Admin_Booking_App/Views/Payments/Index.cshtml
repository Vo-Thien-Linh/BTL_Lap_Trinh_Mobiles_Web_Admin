<form method="get" id="paymentFilterForm" class="payment-filter mb-3" autocomplete="off" asp-controller="Payments" asp-action="Index">
    <div class="payment-filter__search">
        <input name="search" value="@Model.Search" class="form-control" type="search" placeholder="TÃ¬m mÃ£ hÃ³a Ä‘Æ¡n, bá»‡nh nhÃ¢n, dá»‹ch vá»¥..." />
    </div>
    <select name="sourceFilter" class="form-select">
        <option value="">Táº¥t cáº£ nguá»“n</option>
        <option value="Payments" selected="@(Model.SourceFilter == "Payments")">Payments</option>
        <option value="Invoices" selected="@(Model.SourceFilter == "Invoices")">Invoices</option>
    </select>
    <select name="statusFilter" class="form-select">
        <option value="">Táº¥t cáº£ tráº¡ng thÃ¡i</option>
        <option value="Paid" selected="@(Model.StatusFilter == "Paid")">ÄÃ£ thanh toÃ¡n</option>
        <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Chá» xá»­ lÃ½</option>
        <option value="Failed" selected="@(Model.StatusFilter == "Failed")">Tháº¥t báº¡i</option>
    </select>
    <select name="methodFilter" class="form-select">
        <option value="">Táº¥t cáº£ phÆ°Æ¡ng thá»©c</option>
        <option value="CreditCard" selected="@(Model.MethodFilter == "CreditCard")">Tháº»</option>
        <option value="AtmCard" selected="@(Model.MethodFilter == "AtmCard")">Tháº» ATM</option>
        <option value="Cash" selected="@(Model.MethodFilter == "Cash")">Tiá»n máº·t</option>
        <option value="BankTransfer" selected="@(Model.MethodFilter == "BankTransfer")">Chuyá»ƒn khoáº£n</option>
        <option value="MoMo" selected="@(Model.MethodFilter == "MoMo")">MoMo</option>
    </select>
    <div class="medical-date-range payment-date-filter" data-payment-date-range data-has-date-filter="@((Model.FromDate.HasValue || Model.ToDate.HasValue).ToString().ToLowerInvariant())">
        <button class="form-control medical-date-range__button" type="button" data-payment-date-range-toggle>
            <span data-payment-date-range-label>@DateRangeLabel(Model.FromDate, Model.ToDate)</span>
        </button>
        <div class="medical-date-range__popover" data-payment-date-range-panel>
            <div class="payment-date-filter__presets">
                <button type="button" class="btn btn-sm btn-light" data-payment-all-dates>Táº¥t cáº£ ngÃ y</button>
                <button type="button" class="btn btn-sm btn-outline-primary" data-payment-custom-dates>Chá»n khoáº£ng ngÃ y</button>
            </div>
            <div data-payment-custom-date-fields>
                <label class="form-label small text-secondary">Tá»« ngÃ y</label>
                <input name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" type="date" class="form-control" data-payment-date-start />
            </div>
            <div data-payment-custom-date-fields>
                <label class="form-label small text-secondary">Äáº¿n ngÃ y</label>
                <input name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" type="date" class="form-control" data-payment-date-end />
            </div>
        </div>
    </div>
    <div class="filter-validation-message @(string.IsNullOrWhiteSpace(Model.FilterError) ? "" : "is-visible")" data-filter-error>
        @Model.FilterError
    </div>
</form>

<div id="paymentResults" class="card panel-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0 admin-table">
                <thead>
                    <tr class="text-secondary">
                        <th class="payment-select-col">Chá»n</th>
                        <th>MÃ£ hÃ³a Ä‘Æ¡n</th>
                        <th>Bá»‡nh nhÃ¢n</th>
                        <th>Dá»‹ch vá»¥</th>
                        <th>Sá»‘ tiá»n</th>
                        <th>NgÃ y thanh toÃ¡n</th>
                        <th>PhÆ°Æ¡ng thá»©c</th>
                        <th>Tráº¡ng thÃ¡i</th>
                        <th class="text-end">Xử lý</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Transactions.Count == 0)
                {
                    <tr>
                        <td colspan="9">
                            <div class="empty-state empty-state--rich">
                                <div class="empty-state__icon" aria-hidden="true">
                                    <svg width="34" height="34" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <rect x="4" y="6" width="16" height="12" rx="3" stroke="currentColor" stroke-width="1.8" />
                                        <path d="M4 10h16M8 15h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                                    </svg>
                                </div>
                                <div class="empty-state__title">KhÃ´ng tÃ¬m tháº¥y giao dá»‹ch phÃ¹ há»£p vá»›i bá»™ lá»c.</div>
                                <button type="button" class="btn btn-outline-secondary btn-sm" data-clear-payment-filters>XÃ³a bá»™ lá»c</button>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var t in Model.Transactions)
                    {
                        <tr class="payment-select-row" data-payment-row>
                            <td class="payment-select-col">
                                <input class="form-check-input"
                                       type="radio"
                                       name="selectedInvoice"
                                       value="@t.Id"
                                       data-invoice-id="@t.Id"
                                       data-source-collection="@t.SourceCollection"
                                       aria-label="Chá»n hÃ³a Ä‘Æ¡n @t.InvoiceCode" />
                            </td>
                            <td><a href="#" class="admin-link">@t.InvoiceCode</a></td>
                            <td><div class="person-cell"><div class="avatar">@Initials(t.PatientName)</div><div class="fw-semibold">@ValueOrDash(t.PatientName)</div></div></td>
                            <td>@ValueOrDash(t.ServiceName)</td>
                            <td class="fw-semibold">@Vnd(t.AmountVnd)</td>
                            <td><div class="fw-semibold">@t.PaidAt.ToString("dd/MM/yyyy")</div><div class="text-secondary small">@t.PaidAt.ToString("HH:mm")</div></td>
                            <td>@MethodText(t.Method)</td>
                            <td><span class="admin-pill @StatusClass(t.Status)">@StatusText(t.Status)</span></td>
                            <td class="text-end">
                                @if (t.Status == Web_Admin_Booking_App.Models.TransactionStatus.Pending)
                                {
                                    <div class="d-inline-flex gap-1">
                                        <form asp-controller="Payments" asp-action="MarkPaid" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@t.Id" />
                                            <input type="hidden" name="sourceCollection" value="@t.SourceCollection" />
                                            <button class="btn btn-sm btn-success" type="submit">Đã thu</button>
                                        </form>
                                        <form asp-controller="Payments" asp-action="MarkFailed" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@t.Id" />
                                            <input type="hidden" name="sourceCollection" value="@t.SourceCollection" />
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Thất bại</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-secondary small">-</span>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 p-3 border-top">
            <div class="text-secondary small">Hiá»ƒn thá»‹ @Model.Transactions.Count giao dá»‹ch</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
(() => {
    const form = document.getElementById('paymentFilterForm');
    const results = document.getElementById('paymentResults');
    const exportButton = document.getElementById('exportInvoicePdf');
    const range = document.querySelector('[data-payment-date-range]');
    const toggle = document.querySelector('[data-payment-date-range-toggle]');
    const label = document.querySelector('[data-payment-date-range-label]');
    const start = document.querySelector('[data-payment-date-start]');
    const end = document.querySelector('[data-payment-date-end]');
    const allDates = document.querySelector('[data-payment-all-dates]');
    const customDates = document.querySelector('[data-payment-custom-dates]');
    const customFields = document.querySelectorAll('[data-payment-custom-date-fields]');
    const error = form?.querySelector('[data-filter-error]');
    if (!form || !results) return;

    let timer;
    let dateMode = range?.dataset.hasDateFilter === 'true' ? 'custom' : 'all';
    const allDatesLabel = 'Táº¥t cáº£ ngÃ y';
    const customDatesLabel = 'Chá»n khoáº£ng ngÃ y';

    const clearSelection = () => {
        if (!exportButton) return;
        exportButton.classList.add('d-none');
        exportButton.setAttribute('href', '#');
        exportButton.setAttribute('aria-disabled', 'true');
    };

    const selectInvoice = (radio) => {
        if (!radio || !exportButton) return;
        const baseUrl = exportButton.dataset.receiptBaseUrl || '/Payments/ReceiptPdf';
        const params = new URLSearchParams({
            id: radio.dataset.invoiceId || radio.value || ''
        });
        if (radio.dataset.sourceCollection) {
            params.set('sourceCollection', radio.dataset.sourceCollection);
        }
        exportButton.href = `${baseUrl}?${params.toString()}`;
        exportButton.classList.remove('d-none');
        exportButton.removeAttribute('aria-disabled');
        results.querySelectorAll('[data-payment-row]').forEach(row => row.classList.remove('is-selected'));
        radio.closest('[data-payment-row]')?.classList.add('is-selected');
    };

    const setError = (message) => {
        if (!error) return;
        error.textContent = message || '';
        error.classList.toggle('is-visible', Boolean(message));
        [start, end].forEach(input => input?.classList.toggle('is-invalid', Boolean(message)));
        form.querySelector('[name="search"]')?.classList.toggle('is-invalid', Boolean(message && message.includes('100')));
    };

    const updateRangeLabel = () => {
        if (!label || !start || !end) return;
        customFields.forEach(field => field.classList.toggle('d-none', dateMode !== 'custom'));

        if (dateMode !== 'custom') {
            label.textContent = allDatesLabel;
            return;
        }

        if (start.value && end.value) label.textContent = `${start.value} - ${end.value}`;
        else if (start.value) label.textContent = `Tá»« ${start.value}`;
        else if (end.value) label.textContent = `Äáº¿n ${end.value}`;
        else label.textContent = customDatesLabel;
    };

    const validateFilters = () => {
        const search = form.querySelector('[name="search"]')?.value?.trim() || '';
        if (search.length > 100) return 'Tá»« khÃ³a tÃ¬m kiáº¿m khÃ´ng Ä‘Æ°á»£c vÆ°á»£t quÃ¡ 100 kÃ½ tá»±.';
        if (dateMode === 'custom' && start?.value && end?.value && end.value < start.value) return 'NgÃ y káº¿t thÃºc pháº£i lá»›n hÆ¡n hoáº·c báº±ng ngÃ y báº¯t Ä‘áº§u.';
        return '';
    };

    const getBasePath = () => {
        const action = form.getAttribute('action');
        return action && action.trim() ? action : window.location.pathname;
    };

    const buildUrl = () => {
        const params = new URLSearchParams(new FormData(form));
        if (dateMode !== 'custom') {
            params.delete('fromDate');
            params.delete('toDate');
        }
        for (const [key, value] of [...params.entries()]) {
            if (!value) params.delete(key);
        }
        const query = params.toString();
        const basePath = getBasePath();
        return query ? `${basePath}?${query}` : basePath;
    };

    const fetchResults = async () => {
        const validationMessage = validateFilters();
        setError(validationMessage);
        if (validationMessage) return;

        const url = buildUrl();
        results.classList.add('is-loading');
        try {
            const response = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            const html = await response.text();
            const doc = new DOMParser().parseFromString(html, 'text/html');
            const nextResults = doc.getElementById('paymentResults');
            if (nextResults) {
                results.innerHTML = nextResults.innerHTML;
                clearSelection();
                window.history.replaceState(null, '', url);
            }
        } finally {
            results.classList.remove('is-loading');
        }
    };

    const scheduleFetch = (delay = 250) => {
        clearTimeout(timer);
        timer = setTimeout(fetchResults, delay);
    };

    form.querySelector('[name="search"]')?.addEventListener('input', () => scheduleFetch(350));
    form.querySelectorAll('select').forEach(select => select.addEventListener('change', () => scheduleFetch(0)));
    [start, end].forEach(input => input?.addEventListener('change', () => {
        dateMode = 'custom';
        updateRangeLabel();
        scheduleFetch(0);
    }));

    toggle?.addEventListener('click', () => range?.classList.toggle('is-open'));
    allDates?.addEventListener('click', () => {
        dateMode = 'all';
        if (start) start.value = '';
        if (end) end.value = '';
        setError('');
        updateRangeLabel();
        range?.classList.remove('is-open');
        scheduleFetch(0);
    });
    customDates?.addEventListener('click', () => {
        dateMode = 'custom';
        updateRangeLabel();
        start?.focus();
    });
    document.addEventListener('click', event => {
        if (range && !range.contains(event.target)) range.classList.remove('is-open');
    });

    results.addEventListener('click', event => {
        const row = event.target.closest('[data-payment-row]');
        if (row && !event.target.closest('a, button')) {
            const radio = row.querySelector('input[name="selectedInvoice"]');
            if (radio) {
                radio.checked = true;
                selectInvoice(radio);
            }
            return;
        }

        if (!event.target.closest('[data-clear-payment-filters]')) return;
        form.reset();
        dateMode = 'all';
        if (start) start.value = '';
        if (end) end.value = '';
        updateRangeLabel();
        setError('');
        clearSelection();
        scheduleFetch(0);
    });

    results.addEventListener('change', event => {
        if (event.target.matches('input[name="selectedInvoice"]')) {
            selectInvoice(event.target);
        }
    });

    updateRangeLabel();
    clearSelection();
})();
    </script>
}

@functions {
    private static string DateRangeLabel(DateOnly? fromDate, DateOnly? toDate)
    {
        if (fromDate.HasValue && toDate.HasValue) return $"{fromDate:yyyy-MM-dd} - {toDate:yyyy-MM-dd}";
        if (fromDate.HasValue) return $"Tá»« {fromDate:yyyy-MM-dd}";
        if (toDate.HasValue) return $"Äáº¿n {toDate:yyyy-MM-dd}";
        return "Táº¥t cáº£ ngÃ y";
    }

    private static string ValueOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "BN";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 1) return parts[0][..1].ToUpperInvariant();
        return (parts[0][..1] + parts[^1][..1]).ToUpperInvariant();
    }

    private static string Vnd(decimal amount)
    {
        var v = string.Format(System.Globalization.CultureInfo.GetCultureInfo("vi-VN"), "{0:N0}", amount);
        return v + " Ä‘";
    }

    private static string MethodText(Web_Admin_Booking_App.Models.PaymentMethod method) => method switch
    {
        Web_Admin_Booking_App.Models.PaymentMethod.CreditCard => "Tháº»",
        Web_Admin_Booking_App.Models.PaymentMethod.AtmCard => "Tháº» ATM",
        Web_Admin_Booking_App.Models.PaymentMethod.Cash => "Tiá»n máº·t",
        Web_Admin_Booking_App.Models.PaymentMethod.BankTransfer => "Chuyá»ƒn khoáº£n",
        Web_Admin_Booking_App.Models.PaymentMethod.MoMo => "MoMo",
        _ => "-"
    };

    private static string StatusText(Web_Admin_Booking_App.Models.TransactionStatus status) => status switch
    {
        Web_Admin_Booking_App.Models.TransactionStatus.Paid => "ÄÃ£ thanh toÃ¡n",
        Web_Admin_Booking_App.Models.TransactionStatus.Pending => "Chá» xá»­ lÃ½",
        Web_Admin_Booking_App.Models.TransactionStatus.Failed => "Tháº¥t báº¡i",
        _ => "-"
    };

    private static string StatusClass(Web_Admin_Booking_App.Models.TransactionStatus status) => status switch
    {
        Web_Admin_Booking_App.Models.TransactionStatus.Paid => "admin-pill--paid",
        Web_Admin_Booking_App.Models.TransactionStatus.Pending => "admin-pill--pending",
        Web_Admin_Booking_App.Models.TransactionStatus.Failed => "admin-pill--failed",
        _ => "admin-pill--paused"
    };
}
