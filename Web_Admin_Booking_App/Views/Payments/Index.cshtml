</div>

<div class="row g-3 mb-3">
    <div class="col-md-6 col-lg-4">
        <div class="card stat-card"><div class="card-body"><div class="stat-card__label text-uppercase">Tá»•ng doanh thu</div><div class="stat-card__value">@Vnd(Model.TotalRevenue)</div><div class="stat-card__hint text-danger">+@Model.TotalRevenueChangePercent.ToString("0.#")%</div></div></div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card stat-card"><div class="card-body"><div class="stat-card__label text-uppercase">Giao dá»‹ch thÃ nh cÃ´ng</div><div class="stat-card__value">@Model.SuccessfulToday</div><div class="stat-card__hint text-secondary">HÃ´m nay</div></div></div>
    </div>
    <div class="col-md-12 col-lg-4">
        <div class="card stat-card"><div class="card-body"><div class="stat-card__label text-uppercase">Giao dá»‹ch chá» xá»­ lÃ½</div><div class="stat-card__value">@Model.PendingCount</div><div class="stat-card__hint text-danger">@Model.PendingNeedsApprovalCount cáº§n duyá»‡t</div></div></div>
